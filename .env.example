# CryptoLabs Proxy — Environment Variables
# Copy to .env and fill in real values. Never commit .env!

# --- Authentication ---
FLEET_ADMIN_USER=admin
FLEET_ADMIN_PASS=changeme            # REQUIRED — set a strong password
AUTH_SECRET_KEY=                      # Auto-generated if empty (set for persistence across restarts)
AUTH_TOKEN_EXPIRY_HOURS=24
AUTH_DATA_DIR=/data/auth

# --- Auth Server ---
AUTH_PORT=8081

# --- DC Watchdog SSO Integration ---
WATCHDOG_API_KEY=                     # sk-ipmi-xxx format from CryptoLabs subscription
WATCHDOG_URL=https://watchdog.cryptolabs.co.za

# --- Internal API ---
INTERNAL_API_TOKEN=                   # Shared secret for dc-overview/ipmi-monitor config API access
SITE_NAME=DC Overview                 # Display name for the fleet
